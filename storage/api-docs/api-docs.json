{
    "openapi": "3.0.0",
    "info": {
        "title": "PrintFlow API - Moran Creative",
        "description": "API para gestión de pedidos de impresión 3D",
        "contact": {
            "email": "admin@morancreative.com"
        },
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "http://127.0.0.1:8000",
            "description": "Servidor local"
        },
        {
            "url": "/api"
        }
    ],
    "paths": {
        "/api/auth/register": {
            "post": {
                "tags": [
                    "Autenticación"
                ],
                "summary": "Registrar nuevo cliente",
                "operationId": "eb3623f9bcd09a1dacbefaac07aed1bb",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "name",
                                    "email",
                                    "password",
                                    "password_confirmation"
                                ],
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "example": "Juan Pérez"
                                    },
                                    "email": {
                                        "type": "string",
                                        "example": "juan@ejemplo.com"
                                    },
                                    "password": {
                                        "type": "string",
                                        "example": "MiPassword123!"
                                    },
                                    "password_confirmation": {
                                        "type": "string"
                                    },
                                    "phone": {
                                        "type": "string",
                                        "example": "981 234 5678"
                                    },
                                    "address": {
                                        "type": "string"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Registro exitoso"
                    },
                    "422": {
                        "description": "Error de validación"
                    }
                }
            }
        },
        "/api/auth/login": {
            "post": {
                "tags": [
                    "Autenticación"
                ],
                "summary": "Iniciar sesión",
                "operationId": "f77777235d676b651c9465807d8f9485",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "email",
                                    "password"
                                ],
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "example": "admin@morancreative.com"
                                    },
                                    "password": {
                                        "type": "string",
                                        "example": "Admin1234!"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Login exitoso",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string"
                                        },
                                        "token": {
                                            "type": "string"
                                        },
                                        "user": {
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Credenciales incorrectas"
                    }
                }
            }
        },
        "/api/auth/logout": {
            "post": {
                "tags": [
                    "Autenticación"
                ],
                "summary": "Cerrar sesión",
                "operationId": "c4b3c6f1776909e546a421283c044ac3",
                "responses": {
                    "200": {
                        "description": "Sesión cerrada"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/auth/me": {
            "get": {
                "tags": [
                    "Autenticación"
                ],
                "summary": "Obtener usuario autenticado",
                "operationId": "57247eca7a7733a6b79ce17999f79422",
                "responses": {
                    "200": {
                        "description": "Datos del usuario"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/orders": {
            "get": {
                "tags": [
                    "Pedidos"
                ],
                "summary": "Listar pedidos",
                "description": "Admin ve todos los pedidos. Cliente solo ve los suyos.",
                "operationId": "803fc5d32177a888e12dd7a8f9d0e6d4",
                "parameters": [
                    {
                        "name": "status",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "enum": [
                                "solicitado",
                                "cotizado",
                                "aceptado",
                                "en_produccion",
                                "listo",
                                "entregado",
                                "rechazado"
                            ]
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Lista paginada de pedidos"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            },
            "post": {
                "tags": [
                    "Pedidos"
                ],
                "summary": "Crear nuevo pedido",
                "description": "El cliente sube su diseño STL/OBJ junto con las especificaciones.",
                "operationId": "33d737c93193573b1687e463b1562642",
                "requestBody": {
                    "required": true,
                    "content": {
                        "multipart/form-data": {
                            "schema": {
                                "properties": {
                                    "notes": {
                                        "type": "string",
                                        "example": "Quiero acabado liso"
                                    },
                                    "end_use": {
                                        "type": "string",
                                        "example": "prototipo"
                                    },
                                    "deadline": {
                                        "type": "string",
                                        "format": "date",
                                        "example": "2026-04-01"
                                    },
                                    "files[]": {
                                        "type": "array",
                                        "items": {
                                            "type": "string",
                                            "format": "binary"
                                        }
                                    },
                                    "items[0][piece_name]": {
                                        "type": "string",
                                        "example": "Soporte de cámara"
                                    },
                                    "items[0][quantity]": {
                                        "type": "integer",
                                        "example": 2
                                    },
                                    "items[0][material_id]": {
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "items[0][color_id]": {
                                        "type": "integer",
                                        "example": 3
                                    },
                                    "items[0][finish_id]": {
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "items[0][infill_percent]": {
                                        "type": "integer",
                                        "example": 20
                                    },
                                    "items[0][dim_x]": {
                                        "type": "number",
                                        "example": 50
                                    },
                                    "items[0][dim_y]": {
                                        "type": "number",
                                        "example": 30
                                    },
                                    "items[0][dim_z]": {
                                        "type": "number",
                                        "example": 20
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Pedido creado exitosamente",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string"
                                        },
                                        "ticket": {
                                            "type": "string",
                                            "example": "MC-0042"
                                        },
                                        "order": {
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Error de validación"
                    },
                    "500": {
                        "description": "Error interno"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/orders/{id}": {
            "get": {
                "tags": [
                    "Pedidos"
                ],
                "summary": "Ver detalle de un pedido",
                "operationId": "323fecf06eebc01290343e81c470453f",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        },
                        "example": 1
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Detalle completo del pedido con historial"
                    },
                    "403": {
                        "description": "No autorizado"
                    },
                    "404": {
                        "description": "Pedido no encontrado"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/orders/{id}/quote": {
            "patch": {
                "tags": [
                    "Pedidos - Admin"
                ],
                "summary": "Enviar cotización al cliente",
                "description": "Solo el administrador puede cotizar. El pedido debe estar en estado 'solicitado'.",
                "operationId": "2d8cf01cbb90299762a66393854d08be",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "quoted_price"
                                ],
                                "properties": {
                                    "quoted_price": {
                                        "type": "number",
                                        "format": "float",
                                        "example": 850
                                    },
                                    "admin_notes": {
                                        "type": "string",
                                        "example": "Incluye lijado y envío en 5 días hábiles."
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Cotización enviada",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string"
                                        },
                                        "order": {
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "403": {
                        "description": "Solo el admin puede cotizar"
                    },
                    "422": {
                        "description": "Estado inválido o precio requerido"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/orders/{id}/respond": {
            "patch": {
                "tags": [
                    "Pedidos"
                ],
                "summary": "Cliente acepta o rechaza la cotización",
                "description": "Solo el dueño del pedido puede responder. El pedido debe estar en estado 'cotizado'.",
                "operationId": "d982dcf96f31008d090adf0725f44b48",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "action"
                                ],
                                "properties": {
                                    "action": {
                                        "type": "string",
                                        "enum": [
                                            "accept",
                                            "reject"
                                        ],
                                        "example": "accept"
                                    },
                                    "note": {
                                        "type": "string",
                                        "example": "El precio me parece alto."
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Respuesta registrada"
                    },
                    "403": {
                        "description": "No autorizado o estado inválido"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/orders/{id}/status": {
            "patch": {
                "tags": [
                    "Pedidos - Admin"
                ],
                "summary": "Actualizar estado de producción",
                "description": "Solo admin. Transiciones válidas: aceptado→en_produccion→listo→entregado. Envía correo automático al cliente.",
                "operationId": "2c5ba93b32a341cd02599628ea75e6ae",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "status"
                                ],
                                "properties": {
                                    "status": {
                                        "type": "string",
                                        "enum": [
                                            "en_produccion",
                                            "listo",
                                            "entregado"
                                        ]
                                    },
                                    "note": {
                                        "type": "string",
                                        "example": "Iniciando impresión"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Estado actualizado y correo enviado"
                    },
                    "422": {
                        "description": "Transición de estado inválida"
                    },
                    "403": {
                        "description": "Solo el admin puede hacer esto"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/orders/files/{fileId}/download": {
            "get": {
                "tags": [
                    "Pedidos"
                ],
                "summary": "Descargar archivo STL/OBJ de un pedido",
                "description": "Admin descarga cualquier archivo. Cliente solo descarga archivos de sus propios pedidos.",
                "operationId": "f54053852a74ca9b4aac20c09c650e5a",
                "parameters": [
                    {
                        "name": "fileId",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Descarga del archivo"
                    },
                    "403": {
                        "description": "No autorizado"
                    },
                    "404": {
                        "description": "Archivo no encontrado"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/orders/{id}/payment-proof": {
            "post": {
                "tags": [
                    "Pedidos"
                ],
                "summary": "Subir comprobante de pago",
                "description": "El cliente sube una imagen de su comprobante. El admin la valida manualmente.",
                "operationId": "47514e2f98ba857542f21c8161dbf845",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "multipart/form-data": {
                            "schema": {
                                "required": [
                                    "proof"
                                ],
                                "properties": {
                                    "proof": {
                                        "description": "Imagen del comprobante (JPG/PNG, máx 5MB)",
                                        "type": "string",
                                        "format": "binary"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Comprobante subido exitosamente"
                    },
                    "400": {
                        "description": "No se recibió archivo"
                    },
                    "403": {
                        "description": "No autorizado"
                    },
                    "422": {
                        "description": "Archivo inválido"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        }
    },
    "components": {
        "securitySchemes": {
            "bearerAuth": {
                "type": "http",
                "bearerFormat": "JWT",
                "scheme": "bearer"
            }
        }
    },
    "tags": [
        {
            "name": "Autenticación",
            "description": "Autenticación"
        },
        {
            "name": "Pedidos",
            "description": "Pedidos"
        },
        {
            "name": "Pedidos - Admin",
            "description": "Pedidos - Admin"
        }
    ]
}