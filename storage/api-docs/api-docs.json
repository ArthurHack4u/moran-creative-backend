        "/api/orders": {
            "get": {
                "tags": [
                    "Pedidos"
                ],
                "summary": "Listar pedidos",
                "description": "Admin ve todos los pedidos. Cliente solo ve los suyos.",
                "operationId": "803fc5d32177a888e12dd7a8f9d0e6d4",
                "parameters": [
                    {
                        "name": "status",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "enum": [
                                "solicitado",
                                "cotizado",
                                "aceptado",
                                "en_produccion",
                                "listo",
                                "entregado",
                                "rechazado"
                            ]
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Lista paginada de pedidos"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            },
            "post": {
                "tags": [
                    "Pedidos"
                ],
                "summary": "Crear nuevo pedido",
                "description": "El cliente sube su diseño STL/OBJ junto con las especificaciones.",
                "operationId": "33d737c93193573b1687e463b1562642",
                "requestBody": {
                    "required": true,
                    "content": {
                        "multipart/form-data": {
                            "schema": {
                                "properties": {
                                    "notes": {
                                        "type": "string",
                                        "example": "Quiero acabado liso"
                                    },
                                    "end_use": {
                                        "type": "string",
                                        "example": "prototipo"
                                    },
                                    "deadline": {
                                        "type": "string",
                                        "format": "date",
                                        "example": "2026-04-01"
                                    },
                                    "files[]": {
                                        "type": "array",
                                        "items": {
                                            "type": "string",
                                            "format": "binary"
                                        }
                                    },
                                    "items[0][piece_name]": {
                                        "type": "string",
                                        "example": "Soporte de cámara"
                                    },
                                    "items[0][quantity]": {
                                        "type": "integer",
                                        "example": 2
                                    },
                                    "items[0][material_id]": {
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "items[0][color_id]": {
                                        "type": "integer",
                                        "example": 3
                                    },
                                    "items[0][finish_id]": {
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "items[0][infill_percent]": {
                                        "type": "integer",
                                        "example": 20
                                    },
                                    "items[0][dim_x]": {
                                        "type": "number",
                                        "example": 50
                                    },
                                    "items[0][dim_y]": {
                                        "type": "number",
                                        "example": 30
                                    },
                                    "items[0][dim_z]": {
                                        "type": "number",
                                        "example": 20
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Pedido creado exitosamente",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string"
                                        },
                                        "ticket": {
                                            "type": "string",
                                            "example": "MC-0042"
                                        },
                                        "order": {
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Error de validación"
                    },
                    "500": {
                        "description": "Error interno"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
